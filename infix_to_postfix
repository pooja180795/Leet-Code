#include <stdio.h>
void getop();
int prece(int c);

int main()
{
    printf("Enter your infix notation: ");
    getop();
    return 0;
}

void getop()
{
    int c, i = 0, j = 0;
    char stack[25], op_str[25];
    while( (c = getchar()) != '\0' && c != '\n')
    {
        if(c == '(')
        {
            stack[i++] = c;
        }
        else if(c >= '0' && c <= '9')
        {
            op_str[j++] = c;
        }
        else if(c == ')')
        {
            for(i = i - 1; stack[i] != '('; i--)
            {
                op_str[j++] = stack[i];
            }
           stack[i] = '\0';

         }
        else 
        {
            i--;
            int curr_prece = prece(c);
            while(i >= 0 && prece(stack[i]) >= curr_prece)
            {
                op_str[j++] = stack[i--];
            }
            i++;
            stack[i++] = c;
            
        }
    }
    if (stack[0] != '\0')
    {
        for(i = i - 1; i >= 0; i--)
        {
            op_str[j++] = stack[i];
        }
        stack[i] = '\0';
    }
    op_str[j] = '\0';
    for(int k = 0; op_str[k] != '\0'; k++)
    {
        printf("%c",op_str[k]);
    }
    
}

int prece(int c)
{
    if(c == '(')
        return 0;
    if(c == '-' || c == '+')
    {
        return 1;
    }
    else if(c == '*' || c == '/')
    {
        return 2;
    }
}
