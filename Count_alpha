#include <stdio.h>

int main() {
    int c;
    char str[] = "a abAB";
    char arr[256] = {0};
    for(int i = 0; str[i] != '\0'; i++)
    {
        arr[str[i]]++;
    }
    for(int i = 0; i <= 255; i++)
    {
        if(arr[i] > 0 && i != ' ')
        {
            printf("%c:%d\n",i, arr[i]);
        }
    }
    return 0;
}
