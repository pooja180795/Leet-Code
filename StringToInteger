#include <stdio.h>
int str_to_int(char arr[]);
int main() {
     char arr[] = "65321";
     int number = str_to_int(arr);
     printf("number= %d", number);
     return 0;
}

int str_to_int(char arr[])
{
    int number = 0;
    for(int i = 0; arr[i] != '\0'; i++)
    {
        number = (number * 10) + arr[i] - '0';
    }
    return number;
}
