#include <stdio.h>
#include<ctype.h>
double atof(char s[]);

int main()
{
    char s[] = "987e-1";
    double float_val;
    float_val = atof(s);
    printf("val = %f", float_val);
}

/* convert string to double */
double atof(char s[])
{
    double val, power, new_val = 0;
    int i, sign;

    for(i = 0 ; isspace(s[i]); i++) // skip white space
        ;

    sign = (s[i] == '-') ? -1 : 1 ;
    if(s[i] == '-' || s[i] == '+')
        i++;
    for(val = 0.0; isdigit(s[i]); i++)
        val = 10.0 * val + (s[i] - '0');
    if(s[i] == '.')
        i++;
    for(power = 1.0; isdigit(s[i]); i++)
    {
        val = 10.0 * val + (s[i] - '0');
        power = power * 10;
    }
    if(s[i] == 'e')
        i++;
    if(s[i] == '-')
        i++;
    if(isdigit(s[i]))
    {   
        new_val = s[i] - '0';
    }
    while(new_val > 0)
    {
        power = power * 10;
        new_val--;
    }
    printf("%f\n", power);
    return (sign * val) / power;
    
}
